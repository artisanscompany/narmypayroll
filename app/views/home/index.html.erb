<% content_for :title, "NARMY Portal v1" %>
<% content_for :head do %>
  <meta
    name="description"
    content="NARMY Portal v1 is a Rails deployment surface for the Nigerian Army Integrated Personnel & Payroll System platform stack."
  >
<% end %>

<main class="shell">
  <section class="hero">
    <p class="eyebrow">Nigerian Army Integrated Personnel &amp; Payroll System</p>
    <h1>Operational portal for the NARMY rollout.</h1>
    <p class="lede">
      Rails application deployed through Coolify with dedicated PostgreSQL and Redis services.
      This endpoint is the first live surface for the NARMY platform topology and its production runtime.
    </p>

    <div class="hero-actions">
      <a class="button button-primary" href="/up">Health Check</a>
      <span class="meta-pill"><%= Rails.env %></span>
      <span class="meta-pill">Rails <%= Rails.version %></span>
      <span class="meta-pill">Ruby <%= RUBY_VERSION %></span>
    </div>
  </section>

  <section class="metric-grid" aria-label="Readiness metrics">
    <% @readiness_metrics.each do |metric| %>
      <article class="metric-card">
        <strong><%= metric[:value] %></strong>
        <span><%= metric[:label] %></span>
      </article>
    <% end %>
  </section>

  <section class="status-grid" aria-label="Service status">
    <% @service_statuses.each do |service| %>
      <article class="status-card">
        <div class="status-header">
          <h2><%= service.label %></h2>
          <span class="status-badge status-<%= service.state %>"><%= service.state %></span>
        </div>
        <p><%= service.detail %></p>
      </article>
    <% end %>
  </section>

  <section class="notes">
    <% @notes.each do |note| %>
      <div class="note">
        <h2><%= note[:title] %></h2>
        <p><%= note[:copy] %></p>
      </div>
    <% end %>
  </section>
</main>
