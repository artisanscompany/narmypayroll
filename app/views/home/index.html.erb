<% content_for :title, "Overview · Army Finance Payroll" %>

<div class="page-stack">
  <section class="hero">
    <div class="hero-copy hero-panel">
      <p class="eyebrow">Payroll Prototype</p>
      <h1>Army Finance<br>Payroll Command</h1>
      <p>
        A deployable Rails prototype for personnel self-service, payroll records, and secure document delivery. It carries the
        approved prototype's major journeys into a live runtime backed by PostgreSQL, Redis, and Active Storage.
      </p>
      <div class="button-row">
        <%= link_to "Open login surface", login_path, class: "button button--primary" %>
        <%= link_to "Review pay documents", payroll_path, class: "button button--secondary" %>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="kicker">Live service check</p>
      <ul class="timeline">
        <% @service_statuses.each do |service| %>
          <li>
            <div>
              <strong><%= service.label %></strong>
              <span class="muted"><%= service.detail %></span>
            </div>
            <span class="<%= status_pill_class(service.state) %>"><%= service.state %></span>
          </li>
        <% end %>
      </ul>
      <div class="highlight-callout">
        <p class="note">
          Production expects the app to run behind <strong><%= payroll_host %></strong> with managed PostgreSQL, Redis,
          and object storage services attached through runtime environment variables.
        </p>
      </div>
    </aside>
  </section>

  <section class="panel">
    <p class="kicker">Platform scope</p>
    <h2 class="page-title">Core modules carried over from the approved prototype</h2>
    <ul class="module-list">
      <% @platform_modules.each do |module_name| %>
        <li><%= module_name %></li>
      <% end %>
    </ul>
  </section>

  <section class="section-grid">
    <article class="panel">
      <p class="kicker">Release track</p>
      <ul class="timeline">
        <% @delivery_track.each do |step| %>
          <li>
            <div>
              <strong><%= step[:title] %></strong>
              <span class="muted"><%= step[:detail] %></span>
            </div>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <p class="kicker">Next working surfaces</p>
      <ul class="bullet-list">
        <li>
          <div>
            <strong>Login and onboarding</strong>
            <span class="muted">Army number access, first-time setup, and PIN-led document controls follow the interaction model from the prototype.</span>
          </div>
          <%= link_to "Open", login_path, class: "button button--ghost" %>
        </li>
        <li>
          <div>
            <strong>Personnel self-service</strong>
            <span class="muted">Payslip, inquiry, and profile placeholders reflect the prototype's information architecture.</span>
          </div>
          <%= link_to "Open", personnel_dashboard_path, class: "button button--ghost" %>
        </li>
        <li>
          <div>
            <strong>Admin operations</strong>
            <span class="muted">Division metrics, ticket status, and payroll oversight cards are ready for live data wiring.</span>
          </div>
          <%= link_to "Open", admin_dashboard_path, class: "button button--ghost" %>
        </li>
      </ul>
    </article>
  </section>
</div>
