<% content_for :title, "Pay & Documents · Army Finance Payroll" %>

<div class="page-stack">
  <section class="panel">
    <p class="kicker">Monthly pay</p>
    <h1 class="page-title">Pay and document surface</h1>
    <p class="page-intro" style="color: var(--muted);">
      This page carries the prototype's payslip, deduction summary, and document workflow into Rails so it can be backed by live records later.
    </p>
  </section>

  <section class="two-column">
    <article class="panel">
      <p class="kicker">Current breakdown</p>
      <ul class="detail-list">
        <% @payroll_breakdown.each do |line| %>
          <li>
            <strong><%= line[:label] %></strong>
            <span class="muted"><%= line[:amount] %></span>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <p class="kicker">Document actions</p>
      <ul class="bullet-list">
        <li><div><strong>Download payslip</strong><span class="muted">Generate a signed monthly payslip PDF for secure download.</span></div></li>
        <li><div><strong>Tax certificate</strong><span class="muted">Issue annual tax documentation once payroll history is wired.</span></div></li>
        <li><div><strong>Protected documents</strong><span class="muted">Serve sensitive files through Active Storage with the data node as the storage backend.</span></div></li>
      </ul>
    </article>
  </section>
</div>
