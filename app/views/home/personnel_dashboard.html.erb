<% content_for :title, "Personnel Dashboard · NARMY Portal V1" %>

<div class="page-stack">
  <section class="panel">
    <p class="kicker">Self service</p>
    <h1 class="page-title">Personnel dashboard</h1>
    <p class="page-intro" style="color: var(--muted);">
      This surface follows the prototype's self-service dashboard: latest pay, active inquiries, profile readiness, and quick access to documents.
    </p>
  </section>

  <section class="metric-grid">
    <% @personnel_metrics.each do |metric| %>
      <article class="metric-card">
        <small><%= metric[:label] %></small>
        <strong><%= metric[:value] %></strong>
        <span><%= metric[:note] %></span>
      </article>
    <% end %>
  </section>

  <section class="two-column">
    <article class="panel">
      <p class="kicker">Runtime health</p>
      <ul class="timeline">
        <% @service_statuses.each do |service| %>
          <li>
            <div>
              <strong><%= service.label %></strong>
              <span class="muted"><%= service.detail %></span>
            </div>
            <span class="<%= status_pill_class(service.state) %>"><%= service.state %></span>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <p class="kicker">Support channels</p>
      <ul class="bullet-list">
        <% @support_channels.each do |channel| %>
          <li>
            <div>
              <strong><%= channel[:label] %></strong>
              <span class="muted"><%= channel[:detail] %></span>
            </div>
          </li>
        <% end %>
      </ul>
    </article>
  </section>
</div>
