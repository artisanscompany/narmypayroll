<% content_for :title, "Inquiries · Army Finance Payroll" %>

<div class="page-stack">
  <section class="panel">
    <p class="kicker">Inquiry workflow</p>
    <h1 class="page-title">Inquiries and resolution tracking</h1>
    <p class="page-intro" style="color: var(--muted);">
      A deployable placeholder for the inquiry submission and resolution workflow defined in the prototype.
    </p>
  </section>

  <section class="two-column">
    <article class="table-card">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Issue</th>
            <th>Status</th>
            <th>SLA</th>
          </tr>
        </thead>
        <tbody>
          <% @complaint_rows.each do |row| %>
            <tr>
              <td><%= row[:id] %></td>
              <td>
                <strong><%= row[:title] %></strong><br>
                <span class="muted"><%= "#{row[:filed_on]} · #{row[:owner]}" %></span>
              </td>
              <td><span class="<%= status_pill_class(row[:status]) %>"><%= row[:status] %></span></td>
              <td><%= row[:sla] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </article>

    <article class="panel">
      <div class="form-preview">
        <div class="field">
          <label>Category</label>
          <input type="text" value="Pay" readonly>
        </div>
        <div class="field">
          <label>Subject</label>
          <input type="text" value="Housing allowance variance" readonly>
        </div>
        <div class="field">
          <label>Details</label>
          <textarea readonly>I need a review of the housing allowance shown on the latest payslip.</textarea>
        </div>
        <p class="note">This static form preserves the filing flow while backend models, attachments, and response rules are still being built.</p>
      </div>
    </article>
  </section>
</div>
