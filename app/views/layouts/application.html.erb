<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Army Finance Payroll Prototype" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Army Finance Payroll Prototype">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

  </head>

  <body class="portal-body">
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__brand">
          <%= link_to root_path, class: "brand-mark" do %>
            <%= image_tag "/nigerian-army-logo.svg", alt: "Payroll crest", class: "brand-mark__icon" %>
            <span class="brand-mark__copy">
              <strong>Army Finance Payroll</strong>
              <small>Live prototype on <%= payroll_host %></small>
            </span>
          <% end %>
        </div>
        <nav class="site-nav" aria-label="Payroll prototype">
          <% portal_navigation.each do |label, path| %>
            <%= portal_nav_link(label, path) %>
          <% end %>
        </nav>
      </header>

      <main class="site-main">
        <%= yield %>
      </main>

      <footer class="site-footer">
        <p>
          Built by Army Finance Corp for regulated payroll delivery. Marketing site:
          <%= link_to website_host, website_base_url, class: "footer-link" %>.
        </p>
      </footer>
    </div>
  </body>
</html>
